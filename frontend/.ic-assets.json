[
    {
        "match": "assets/**/*.js",
        "headers": {
            "Content-Type": "application/javascript",
            "Cache-Control": "public, max-age=31536000, immutable"
        }
    },
    {
        "match": "assets/**/*.css",
        "headers": {
            "Content-Type": "text/css",
            "Cache-Control": "public, max-age=31536000, immutable"
        }
    },
    {
        "match": "assets/**/*.(png|jpg|jpeg|gif|svg|ico|webp)",
        "headers": {
            "Cache-Control": "public, max-age=31536000, immutable"
        }
    },
    {
        "match": "index.html",
        "headers": {
            "Cache-Control": "public, max-age=0, must-revalidate"
        }
    },
    {
        "match": "**/*",
        "headers": {
            "X-Content-Type-Options": "nosniff",
            "X-Frame-Options": "DENY",
            "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-eval'; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000 https://icp0.io https://*.icp0.io https://*.ic0.app; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; border-src 'self';"
        }
    }
]